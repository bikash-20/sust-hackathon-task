{
  "version": 2,
  "installCommand": "npm install --prefix frontend-pwa",
  "buildCommand": "npm run build --prefix frontend-pwa",
  "builds": [
    {
      "src": "frontend-pwa/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
